version: '3'

services:
  app:
    build: .
    image: python-container-tool:latest
    hostname: container-tool
    env_file: .env
    ports:
      - "${APP_PORT}:${FLASK_PORT}"
    volumes:
      - ./conf:/app/conf
      - ./logs:/app/logs
      - ./ssh:/app/ssh
      - ./app/templates:/app/app/templates
    depends_on:
      - mongo
    restart: unless-stopped

  mongo:
    image: mongo:7
    hostname: container-tool-mongo
    volumes:
      - mongo_data:/data/db
    restart: unless-stopped

volumes:
  mongo_data:
